# === {label}.service ===
[Unit]
Description={app} plugin + MCP allowlist sync
After=network-online.target

[Service]
Type=oneshot
ExecStart={binary} sync
Nice=10

[Install]
WantedBy=default.target

# === {label}.timer ===
[Unit]
Description=Periodic {app} sync

[Timer]
OnBootSec=2min
OnUnitActiveSec=30min
Persistent=true

[Install]
WantedBy=timers.target

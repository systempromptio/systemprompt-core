# === systemprompt-bridge-sync.service ===
[Unit]
Description=systemprompt.io Bridge plugin + MCP allowlist sync
After=network-online.target

[Service]
Type=oneshot
ExecStart={binary} sync
Nice=10

[Install]
WantedBy=default.target

# === systemprompt-bridge-sync.timer ===
[Unit]
Description=Periodic systemprompt-bridge sync

[Timer]
OnBootSec=2min
OnUnitActiveSec=30min
Persistent=true

[Install]
WantedBy=timers.target

Domain: com.anthropic.claudefordesktop
Format: .mobileconfig (managed preference)

<dict>
  <key>inferenceProvider</key>
  <string>gateway</string>
  <key>inferenceGatewayBaseUrl</key>
  <string>{gateway}</string>
  <key>inferenceGatewayApiKey</key>
  <string>&lt;loopback-secret-from-~/Library/Application Support/systemprompt/cowork-loopback.key&gt;</string>
  <key>inferenceGatewayAuthScheme</key>
  <string>bearer</string>
  <key>disableEssentialTelemetry</key>
  <string>true</string>
  <key>disableNonessentialTelemetry</key>
  <string>true</string>
  <key>disableNonessentialServices</key>
  <string>true</string>
  <key>disableAutoUpdates</key>
  <string>true</string>
  <key>disableDeploymentModeChooser</key>
  <string>true</string>
</dict>
